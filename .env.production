# Production API origin — baked into the bundle at `npm run build` time.
# Changing this later means a REBUILD, not a config edit.
# Matches the nginx plan in travelcrmbackend/deploy/nginx-travelcrm.conf:
#   api.mytripsafar.com  → Spring Boot API (this URL)
#   mytripsafar.com      → this React build (dist/ → /var/www/travelcrm)
VITE_API_URL=https://api.mytripsafar.com/api
