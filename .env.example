# TravelCRM frontend — build-time environment contract.
#
# Copy to `.env` for local dev, or `.env.production` for a production build.
# Vite only exposes variables prefixed VITE_, and it INLINES them at build time —
# these are compiled into the bundle, never read at runtime. Changing one means
# rebuilding and redeploying, not editing a file on the server.
#
# .env and .env.* are gitignored; this example is the only tracked reference.

# ── API origin ──────────────────────────────────────────────────────
# MUST end in /api — every consumer appends bare paths to it.
# Read by: shared/api/http.js, console/api/consoleHttp.js,
#          console/api/consoleNotificationService.js, features/portal/api/portalClient.js,
#          features/assistant/api/assistantClient.js, features/reminders/api/notificationService.js,
#          features/quotation/pages/QuotationWebView.jsx, app/chrome/ImpersonationBanner.jsx,
#          app/chrome/Navbar.jsx, shared/lib/access.js
#
# ⚠ If unset, every one of those silently falls back to http://localhost:8080/api.
# That is a valid URL, so nothing errors at build time — the deployed app simply cannot
# reach its backend from any machine but the server itself. A deploy that forgets this
# points production at localhost instead of failing loudly.
#
# Dev:  leave unset (vite.config.js proxies /api → localhost:8080) or set explicitly.
# Prod: https://api.mytripsafar.com/api
VITE_API_URL=

# ── Cloudinary ──────────────────────────────────────────────────────
# NOT NEEDED ANYMORE. All image uploads (hotel / vehicle / destination / sightseeing,
# quotation builder tabs) now go through the backend's /upload-image endpoints, which
# forward to Cloudinary server-side with the tenant storage quota enforced and bytes
# metered. Cloudinary credentials live only on the backend (CLOUDINARY_CLOUD_NAME /
# CLOUDINARY_API_KEY / CLOUDINARY_API_SECRET env vars on the server).
# The old VITE_CLOUDINARY_CLOUD_NAME / VITE_CLOUDINARY_UPLOAD_PRESET vars are dead —
# nothing in src/ reads them; remove them from any existing .env.
