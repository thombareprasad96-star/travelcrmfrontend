# Cloudinary (unsigned) image upload — used by src/services/DestinationService.js
# Copy this file to ".env" (or ".env.local") and fill in your real values.
#
# Where to find these in the Cloudinary dashboard:
#   CLOUD_NAME    -> Dashboard / Settings -> "Cloud name"
#   UPLOAD_PRESET -> Settings -> Upload -> "Upload presets" -> create one with
#                    Signing Mode = "Unsigned", then copy its name here.

VITE_CLOUDINARY_CLOUD_NAME=your_cloud_name_here
VITE_CLOUDINARY_UPLOAD_PRESET=your_unsigned_preset_here
